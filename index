<!DOCTYPE html>
<script>
    // Prüfen, ob der User am Handy ist
    if (/Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent)) {
        // Falls ja: Leite direkt auf die Präsentations-URL weiter (ohne Iframe)
        // Ersetze die URL unten durch deinen tatsächlichen Link zur Slideshow
        window.location.href = "https://docs.google.com/presentation/d/e/2PACX-1vQYSDiNWgoUySOYEu1qDTetowoaZc7hbNeWHeG8gMveqpJRoWj_qr9QNpmiwHGo1AR9n80qi9nXCbm8/pub?start=true&loop=true&delayms=10000";
    }
</script>
<html lang="de">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Steuerung Pro</title>
    <style>
        :root {
            --bg-color: #121212;
            --card-bg: #1e1e1e;
            --text-color: #ffffff;
            --accent: #bb86fc;
        }
        
        body.theme-light {
            --bg-color: #f4f4f9;
            --card-bg: #ffffff;
            --text-color: #333333;
            --accent: #6200ea;
        }

        body { 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            background: var(--bg-color); 
            color: var(--text-color); 
            margin: 0; 
            padding: 15px; 
            transition: 0.3s;
            display: flex;
            flex-direction: column;
            gap: 20px; 
            max-width: 500px; 
            margin-left: auto;
            margin-right: auto;
        }

        h2, h3 { text-align: center; margin: 0; }

        .extras-bar {
            display: flex;
            justify-content: space-around;
            background: var(--card-bg);
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .icon-btn {
            background: none;
            border: none;
            font-size: 32px;
            cursor: pointer;
            transition: transform 0.2s;
            padding: 5px;
        }
        .icon-btn:active { transform: scale(0.9); }

        .card { 
            background: var(--card-bg); 
            padding: 20px; 
            border-radius: 12px; 
            box-shadow: 0 4px 6px rgba(0,0,0,0.1); 
            display: flex; 
            flex-direction: column; 
            gap: 10px;
        }
        
        button { 
            width: 100%; 
            padding: 18px; 
            border: none; 
            border-radius: 8px; 
            cursor: pointer; 
            font-weight: bold; 
            font-size: 16px; 
            background: #333; 
            color: white; 
        }
        button:active { transform: scale(0.98); }

        input[type="text"], input[type="number"], select { 
            width: 100%; 
            padding: 15px; 
            border-radius: 8px; 
            border: 1px solid #555; 
            box-sizing: border-box;
            font-size: 16px;
            background: var(--bg-color);
            color: var(--text-color);
        }

        .time-input-container { display: flex; gap: 10px; }
        .time-input-container input { text-align: center; }

        .bg-settings-box {
            background: rgba(0,0,0,0.2);
            padding: 15px;
            border-radius: 8px;
            border: 1px solid #444;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }
        body.theme-light .bg-settings-box {
            background: rgba(0,0,0,0.05);
            border: 1px solid #ccc;
        }

        .color-picker-container { display: flex; align-items: center; justify-content: space-between; gap: 15px; }
        input[type="color"] { padding: 0; width: 100px; height: 40px; cursor: pointer; border: none; border-radius: 5px; }

        .btn-werbung { background: #4CAF50; font-size: 18px; }
        .btn-pause { background: #9C27B0; }
        .btn-timer { background: #2196F3; }
        .btn-alert { background: #E91E63; }
        
        .icon-active { background: rgba(255, 255, 255, 0.2); border-radius: 10px; }
    </style>
</head>
<body class="theme-dark" id="app-body">

    <h2>📱 Steuerung Pro</h2>

    <div class="extras-bar">
        <button class="icon-btn" onclick="setMode('blackout')" title="Bildschirm Aus">📴</button>
        <button class="icon-btn" onclick="toggleTheme()" title="Design wechseln">🎨</button>
        <!-- NEU: Angepasster Uhr-Button -->
        <button class="icon-btn" onclick="toggleClock()" title="Uhrzeit / Schriftart wechseln">🕒</button>
        <button class="icon-btn" onclick="toggleWeather()" title="Wetter">🌤️</button>
        <button class="icon-btn" id="btn-logo" onclick="toggleLogo()" title="Sender-Logo ein/aus">🏷️</button>
    </div>

    <button class="btn-werbung" onclick="setMode('werbung')">▶ Standard Werbung starten</button>

    <div class="card">
        <h3>Manuelle Pausen</h3>
        <button class="btn-pause" onclick="setMode('pause5')">⏳ 5 Min Warnung</button>
        <button class="btn-pause" onclick="setMode('pause3')">⏳ 3 Min Warnung</button>
    </div>

    <div class="card">
        <!-- NEU: Text auf Pausentimer geändert -->
        <h3>Pausentimer</h3>
        <div class="time-input-container">
            <input type="number" id="pauseMin" placeholder="Minuten" min="0" value="0">
            <input type="number" id="pauseSec" placeholder="Sekunden" min="0" max="59" value="0">
        </div>
        <button class="btn-timer" onclick="startTimer()">⏱️ Timer starten</button>
    </div>

    <div class="card">
        <h3>📢 Eigene Nachricht</h3>
        <input type="text" id="alertText" placeholder="Nachricht eintippen...">
        
        <div class="time-input-container">
            <input type="number" id="alertMin" placeholder="Minuten" min="0" value="5">
            <input type="number" id="alertSec" placeholder="Sekunden" min="0" max="59" value="0">
        </div>
        
        <div class="bg-settings-box">
            <label style="font-size: 14px; font-weight: bold;">Hintergrund für die Nachricht:</label>
            <select id="bgMode" onchange="updateBgSettings()">
                <option value="color">Feste Farbe</option>
                <option value="blur">Präsentation unscharf (Blur)</option>
                <option value="rainbow">Wechselnde Farbe (Regenbogen)</option>
            </select>
            
            <div id="colorPickerDiv" class="color-picker-container">
                <label style="font-size: 14px;">Wähle eine Farbe:</label>
                <input type="color" id="bgColorInput" value="#000000" onchange="updateBgSettings()">
            </div>
        </div>

        <button class="btn-alert" onclick="startAlertText()">Anzeigen</button>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js";
        import { getDatabase, ref, update, onValue } from "https://www.gstatic.com/firebasejs/10.12.2/firebase-database.js";

        const firebaseConfig = {
            apiKey: "AIzaSyDLvfW6NyXcxAPYakErDOMNiIj9Iii6PO8",
            authDomain: "werbungfersteuern.firebaseapp.com",
            databaseURL: "https://werbungfersteuern-default-rtdb.europe-west1.firebasedatabase.app",
            projectId: "werbungfersteuern",
            storageBucket: "werbungfersteuern.firebasestorage.app",
            messagingSenderId: "630825517269",
            appId: "1:630825517269:web:44cf935bee6c1074c2e25c"
        };

        const db = getDatabase(initializeApp(firebaseConfig));
        
        // Speichere den aktuellen Status lokal mit
        let currentStatus = { mode: "werbung", clockFontIndex: 0 };
        onValue(ref(db, 'status'), (snapshot) => {
            const data = snapshot.val();
            if(data) currentStatus = data;
        });

        window.setMode = function(modeName) {
            update(ref(db, 'status'), { mode: modeName, endTime: null, msg: "" });
        }

        // NEU: Logik für die Uhr (Schriftarten durchschalten)
        window.toggleClock = function() {
            if(currentStatus.mode === "clock") {
                // Wenn schon auf der Uhr, wechsle zur nächsten Schriftart (0 bis 9)
                let nextFont = (currentStatus.clockFontIndex + 1) % 10;
                update(ref(db, 'status'), { clockFontIndex: nextFont });
            } else {
                // Wenn noch nicht auf der Uhr, starte die Uhr (behalte die letzte Schriftart)
                let currentFont = currentStatus.clockFontIndex || 0;
                update(ref(db, 'status'), { mode: "clock", clockFontIndex: currentFont, endTime: null, msg: "" });
            }
        }

        window.startTimer = function() {
            const mins = parseInt(document.getElementById('pauseMin').value) || 0;
            const secs = parseInt(document.getElementById('pauseSec').value) || 0;
            const totalMs = ((mins * 60) + secs) * 1000;
            if (totalMs <= 0) { alert("Bitte Zeit eingeben!"); return; }
            
            update(ref(db, 'status'), { mode: "custom_pause", endTime: Date.now() + totalMs });
            alert("Timer läuft!");
        }

        window.startAlertText = function() {
            const text = document.getElementById('alertText').value;
            const mins = parseInt(document.getElementById('alertMin').value) || 0;
            const secs = parseInt(document.getElementById('alertSec').value) || 0;
            const totalMs = ((mins * 60) + secs) * 1000;
            
            if (!text) { alert("Bitte gib einen Text ein!"); return; }
            if (totalMs <= 0) { alert("Bitte eine gültige Dauer eingeben!"); return; }
            
            updateBgSettings();
            update(ref(db, 'status'), { mode: "alert_text", msg: text, endTime: Date.now() + totalMs });
            document.getElementById('alertText').value = ""; 
            alert("Nachricht auf dem Fernseher!");
        }

        window.updateBgSettings = function() {
            const mode = document.getElementById('bgMode').value;
            const color = document.getElementById('bgColorInput').value;
            document.getElementById('colorPickerDiv').style.display = (mode === "color") ? "flex" : "none";
            update(ref(db, 'background'), { style: mode, color: color });
        }

        let weatherActive = false;
        window.toggleWeather = async function() {
            if (!weatherActive) {
                let city = prompt("Für welche Stadt soll das Wetter angezeigt werden?", "Wien");
                if (city) update(ref(db, 'weather'), { show: true, location: city });
            } else {
                update(ref(db, 'weather'), { show: false });
            }
        }

        let logoActive = false;
        window.toggleLogo = function() {
            logoActive = !logoActive;
            update(ref(db, 'overlay'), { showLogo: logoActive });
        }

        window.toggleTheme = function() {
            let currentTheme = document.getElementById('app-body').className === "theme-dark" ? "theme-light" : "theme-dark";
            update(ref(db, 'settings'), { theme: currentTheme });
        }

        onValue(ref(db, 'settings/theme'), (snapshot) => {
            const theme = snapshot.val();
            if (theme) document.getElementById('app-body').className = theme;
        });
        
        onValue(ref(db, 'weather/show'), (snapshot) => { weatherActive = snapshot.val() || false; });

        onValue(ref(db, 'overlay/showLogo'), (snapshot) => { 
            logoActive = snapshot.val() || false; 
            const btn = document.getElementById('btn-logo');
            if(logoActive) {
                btn.classList.add('icon-active');
            } else {
                btn.classList.remove('icon-active');
            }
        });

        onValue(ref(db, 'background'), (snapshot) => {
            const data = snapshot.val();
            if (data) {
                document.getElementById('bgMode').value = data.style || "color";
                document.getElementById('bgColorInput').value = data.color || "#000000";
                document.getElementById('colorPickerDiv').style.display = (data.style === "color" || !data.style) ? "flex" : "none";
            } else {
                update(ref(db, 'background'), { style: "color", color: "#000000" });
            }
        });
    </script>
</body>
</html>
